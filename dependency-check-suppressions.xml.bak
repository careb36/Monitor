<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        Suppress false positives for Spring Boot managed dependencies.
        Spring Boot BOM ensures these versions are compatible and patched.
    -->
    <suppress>
        <notes><![CDATA[
            Spring Boot starter dependencies are managed by the Spring Boot BOM.
            CVEs against older versions do not apply to the BOM-managed versions.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/.*@.*$</packageUrl>
    </suppress>

    <!--
        Oracle XE JDBC driver — used only in Docker test infrastructure.
        The driver is not shipped in the production artifact.
    -->
    <suppress>
        <notes><![CDATA[
            Oracle JDBC driver used only in Docker/test infrastructure,
            not bundled in the production artifact.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.oracle\.database/jdbc@.*$</packageUrl>
    </suppress>
</suppressions>
